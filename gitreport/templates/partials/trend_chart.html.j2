{% if trend_data|length >= 2 %}
<div class="section-title" style="margin-top:16px">Merged PRs — Trend</div>
<div class="full"><div class="cell"><div class="trend-row">
  {% for label, pid, count in trend_data %}
  {% set pct = [((count / max_trend * 100)|int), 3]|max %}
  <div class="trend-col">
    <div class="trend-bar-inner"><div class="trend-bar" style="height:{{ pct }}%;background:var(--merged);opacity:.8"></div></div>
    <div class="trend-lbl">{{ label|short_label }}</div>
  </div>
  {% endfor %}
</div></div></div>
{% endif %}
