{% from "partials/period_block.html.j2" import period_block %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Repo Report · {{ repo }}</title>
{% if inline_assets %}
<style>{{ css_content|safe }}</style>
{% else %}
<link rel="stylesheet" href="/static/css/report.css">
{% endif %}
</head>
<body>
<div class="noise"></div>
<div class="container">

{% include "partials/header.html.j2" %}
{% include "partials/toc.html.j2" %}
{% include "partials/overview_grid.html.j2" %}
{% include "partials/trend_chart.html.j2" %}

<hr class="divider">

{% for p in periods_data %}
{{ period_block(p, repo, no_summary, stale_branch_days, provider_name) }}
{% if not loop.last %}
<hr class="divider">
{% endif %}
{% endfor %}

{% include "partials/overall_summary.html.j2" %}
{% include "partials/footer.html.j2" %}

</div>
{% if inline_assets %}
<script>{{ js_content|safe }}</script>
{% else %}
<script src="/static/js/report.js"></script>
{% endif %}
</body>
</html>
